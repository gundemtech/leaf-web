---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'destructive';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  external?: boolean;
  class?: string;
}
const { variant = 'primary', size = 'md', href, type = 'button', disabled = false, external = false, class: extraClass } = Astro.props;
const Tag = href ? 'a' : 'button';
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
const classes = `btn btn-${variant} btn-${size}${extraClass ? ' ' + extraClass : ''}`;
---
<Tag
  class={classes}
  href={href}
  type={Tag === 'button' ? type : undefined}
  disabled={Tag === 'button' ? disabled : undefined}
  aria-disabled={disabled || undefined}
  rel={rel}
  target={target}
>
  <slot />
</Tag>

<style>
.btn {
  position: relative;
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-sm);
  border-radius: var(--radius-md);
  font-family: var(--font-body); font-weight: 500;
  border: 1px solid transparent;
  transition:
    background var(--dur-short) var(--ease-standard),
    border-color var(--dur-short) var(--ease-standard),
    box-shadow var(--dur-short) var(--ease-standard),
    transform var(--dur-snap) var(--spring-snappy);
  text-decoration: none;
  white-space: nowrap;
  cursor: pointer;
  overflow: hidden;
  isolation: isolate;
}
.btn[aria-disabled="true"] { opacity: 0.5; pointer-events: none; }

.btn-sm { height: 28px; padding: 0 var(--space-md); font-size: 13px; }
.btn-md { height: 36px; padding: 0 var(--space-lg); font-size: 15px; }
.btn-lg { height: 44px; padding: 0 var(--space-xl); font-size: 17px; }

/* Primary — gradient surface + top shine + green glow */
.btn-primary {
  background: linear-gradient(180deg, var(--accent-emphasis) 0%, var(--accent-primary) 100%);
  color: var(--text-inverse);
  box-shadow:
    inset 0 1px 0 0 color-mix(in srgb, white 24%, transparent),
    0 1px 2px rgba(0, 0, 0, .18),
    0 0 0 0 color-mix(in srgb, var(--accent-primary) 40%, transparent);
}
.btn-primary:hover {
  box-shadow:
    inset 0 1px 0 0 color-mix(in srgb, white 32%, transparent),
    0 2px 6px rgba(0, 0, 0, .22),
    0 0 24px 0 color-mix(in srgb, var(--accent-primary) 38%, transparent);
  transform: translateY(-1px);
}
.btn-primary:active { transform: translateY(0); }

.btn-secondary { background: var(--surface-raised); color: var(--text-primary); border-color: var(--border-subtle); }
.btn-secondary:hover { background: var(--surface-inset); border-color: var(--border-strong); transform: translateY(-1px); }
.btn-secondary:active { transform: translateY(0); }

.btn-ghost { background: transparent; color: var(--text-primary); }
.btn-ghost:hover { background: var(--surface-raised); }

.btn-destructive { background: var(--status-danger); color: var(--text-inverse); }
.btn-destructive:hover {
  background: color-mix(in srgb, var(--status-danger) 85%, black);
  box-shadow: 0 0 24px 0 color-mix(in srgb, var(--status-danger) 30%, transparent);
}
</style>
