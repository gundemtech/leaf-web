---
// MIRRORED: the public changelog (gundemtech/leaf-contact, src/public.ts,
// served at /changelog by the Worker route) hand-mirrors this control's
// markup/styles/behavior. If you change it here — update the mirror there.
---
<button class="theme-toggle" type="button" aria-label="Toggle color theme">
  <svg class="i-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
  <svg class="i-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
</button>

<style>
.theme-toggle {
  display: inline-flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; border-radius: var(--radius-md);
  background: transparent; border: none; color: var(--text-secondary); cursor: pointer;
  transition: background var(--dur-snap) var(--ease-standard), color var(--dur-snap) var(--ease-standard);
}
.theme-toggle:hover { background: var(--surface-raised); color: var(--text-primary); }
/* Icon visibility is token-driven ONLY — an extra `.theme-toggle svg` display
   rule would out-specificity these two and show both icons at once. */
.i-sun { display: var(--theme-toggle-sun, none); }
.i-moon { display: var(--theme-toggle-moon, block); }
</style>

<script>
document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((btn) => {
  btn.addEventListener('click', () => {
    const explicit = document.documentElement.getAttribute('data-theme');
    const isDark = explicit ? explicit === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
    const next = isDark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('leaf-theme', next); } catch {}
  });
});
</script>
