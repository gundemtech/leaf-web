---
interface Props {
  question: string;
  open?: boolean;
}
const { question, open = false } = Astro.props;
---
<details class="accordion" open={open}>
  <summary class="t-title-sm">
    <span class="q">{question}</span>
    <svg class="chevron" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
      <path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </summary>
  <div class="body t-body"><div class="body-inner"><slot /></div></div>
</details>

<style>
.accordion { border-bottom: 1px solid var(--border-subtle); padding: var(--space-lg) 0; }
.accordion summary {
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; list-style: none;
  color: var(--text-primary);
  transition: color var(--dur-snap) var(--ease-standard);
}
.accordion summary::-webkit-details-marker { display: none; }
.accordion summary:hover { color: var(--accent-primary); }
.chevron { color: var(--text-tertiary); transition: transform var(--dur-medium) var(--spring-snappy); }
.accordion[open] .chevron { transform: rotate(180deg); }

/* Smooth expand using grid-template-rows 0fr → 1fr.
   Works without JS because we override the browser's default hide-on-closed
   behavior by laying out .body as a grid (kept in flow even when not open). */
.accordion .body {
  display: grid;
  grid-template-rows: 0fr;
  opacity: 0;
  color: var(--text-secondary);
  transition:
    grid-template-rows var(--dur-medium) var(--ease-emphasized),
    opacity var(--dur-medium) var(--ease-emphasized),
    padding-top var(--dur-medium) var(--ease-emphasized);
  padding-top: 0;
}
.accordion[open] .body {
  grid-template-rows: 1fr;
  opacity: 1;
  padding-top: var(--space-md);
}
.accordion .body-inner { overflow: hidden; min-height: 0; }
</style>

