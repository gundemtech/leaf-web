---
import LeafCard from '../LeafCard.astro';
import LeafEyebrow from '../LeafEyebrow.astro';
import LeafButton from '../LeafButton.astro';
const main = [
  { logo: '/assets/integrations/linear.svg', name: 'Linear', features: ['Issues + comments', 'Cycles + status', 'Labels + assignees'] },
  { logo: '/assets/integrations/github.svg', name: 'GitHub', features: ['Commits + push events', 'PR cycle + reviews', 'Releases + branches'] },
  { logo: '/assets/integrations/slack.svg', name: 'Slack', features: ['Messages + reactions', 'Huddles', 'Status + DND'] },
];
const minor = [
  { name: 'AI tool hooks', desc: 'Claude Code · Cursor · Windsurf · Continue.dev' },
  { name: 'Degraded sources', desc: 'ChatGPT Desktop · GitHub Copilot — best-effort metadata' },
];
const upcoming = ['Notion', 'Figma', 'Jira', 'Calendar', 'Mail'];
---
<section id="integrations" class="layer-b">
  <div class="wrap">
    <LeafEyebrow number="02" label="ACROSS YOUR TOOLS" />
    <h2 class="t-display">Connected to where<br />your team works.</h2>

    <div class="main-grid">
      {main.map(i => (
        <LeafCard variant="raised" padding="generous" interactive>
          <img src={i.logo} alt={i.name} width="40" height="40" />
          <h3 class="t-title-md">{i.name}</h3>
          <ul class="features t-body-sm">
            {i.features.map(f => <li>{f}</li>)}
          </ul>
        </LeafCard>
      ))}
    </div>

    <div class="minor-grid">
      {minor.map(m => (
        <LeafCard variant="rest" padding="regular">
          <h4 class="t-title-sm">{m.name}</h4>
          <p class="t-body-sm muted">{m.desc}</p>
        </LeafCard>
      ))}
    </div>

    <p class="upcoming t-body-sm">
      Coming: {upcoming.join(' · ')}
    </p>

    <LeafButton href="/product#integrations" variant="ghost">View all integrations →</LeafButton>
  </div>
</section>

<style>
.layer-b { padding: var(--space-5xl) 0; }
.layer-b h2 { margin: var(--space-md) 0 var(--space-3xl); }
.main-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); margin-bottom: var(--space-lg); }
.minor-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-md); margin-bottom: var(--space-lg); }
@media (max-width: 768px) { .main-grid, .minor-grid { grid-template-columns: 1fr; } }
.main-grid h3 { margin: var(--space-md) 0 var(--space-sm); }
.features { display: flex; flex-direction: column; gap: var(--space-xs); color: var(--text-secondary); }
.features li::before { content: '— '; color: var(--text-quaternary); }
.muted { color: var(--text-secondary); }
.upcoming { color: var(--text-tertiary); margin-bottom: var(--space-xl); }
</style>
