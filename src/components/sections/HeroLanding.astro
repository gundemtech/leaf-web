---
import LeafButton from '../LeafButton.astro';
---
<section class="hero">
  <div class="top-strip">
    <div class="wrap strip-inner">
      <span class="mono">leaf</span>
      <span class="sep">·</span>
      <span class="mono">memory layer for AI dev teams</span>
      <span class="sep">·</span>
      <span class="mono dim">v1.0.0-alpha.15</span>
      <span class="rec"><span class="rec-dot"></span><span class="mono dim">capturing</span></span>
    </div>
  </div>

  <div class="wrap hero-body">
    <div class="ticker mono" aria-hidden="true">
      <span class="t-row" id="tickerRow">
        <span class="t-time">10:42</span>
        <span class="t-app">Xcode</span>
        <span class="t-sep">→</span>
        <span class="t-text">SessionAggregator.swift</span>
      </span>
    </div>

    <h1 class="big">
      <span class="line one">Stop briefing your AI.</span>
      <span class="line two">It can just know.</span>
    </h1>

    <p class="lead">
      Captured on your Mac. Encrypted locally. Queried by Claude Code,
      Cursor, and Slack through MCP — without screen recording, prompt
      capture, or your manager looking over your shoulder.
    </p>

    <div class="actions">
      <LeafButton variant="primary" size="lg" href="/signup">Install for macOS →</LeafButton>
      <a class="textlink mono" href="https://leaf-docs.gundem.tech" target="_blank" rel="noopener">read the whitepaper ↗</a>
    </div>
  </div>

  <div class="bottom-strip">
    <div class="wrap strip-inner">
      <span class="proof"><span class="mark"></span><span class="mono">default share — nothing</span></span>
      <span class="proof"><span class="mark"></span><span class="mono">never leaves your Mac unencrypted</span></span>
      <span class="proof"><span class="mark"></span><span class="mono">admin has no override</span></span>
      <span class="proof tail"><span class="mono dim">open source · MIT</span></span>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 56px); /* full viewport minus nav */
}

/* TOP / BOTTOM hairline strips ──────────────────────── */
.top-strip {
  border-bottom: 1px solid var(--border-subtle);
  background: color-mix(in srgb, var(--surface-canvas) 70%, transparent);
}
.bottom-strip {
  border-top: 1px solid var(--border-subtle);
  margin-top: auto;
}
.strip-inner {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
  font-size: 11px;
  color: var(--text-tertiary);
  flex-wrap: wrap;
}
.strip-inner .sep { color: var(--text-quaternary); }
.strip-inner .dim { color: var(--text-quaternary); }
.rec {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.rec-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--accent-primary);
  animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(0.8); }
}
@media (prefers-reduced-motion: reduce) {
  .rec-dot { animation: none; }
}

/* HERO BODY ────────────────────────────────────────── */
.hero-body {
  display: flex;
  flex-direction: column;
  flex: 1;
  justify-content: center;
  padding-top: var(--space-5xl);
  padding-bottom: var(--space-5xl);
}

/* TICKER — single line of live-feel event, sits above headline */
.ticker {
  display: inline-flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
  font-size: 11.5px;
  color: var(--text-tertiary);
  height: 16px;
  overflow: hidden;
  opacity: 0;
  animation: fadeUp 700ms 350ms cubic-bezier(.18, .89, .32, 1.28) forwards;
}
.t-row {
  display: inline-flex;
  align-items: center;
  gap: var(--space-md);
  white-space: nowrap;
}
.t-time { color: var(--text-quaternary); }
.t-app { color: var(--text-primary); }
.t-sep { color: var(--text-quaternary); }
.t-text { color: var(--text-secondary); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}
@media (prefers-reduced-motion: reduce) {
  .ticker { opacity: 1; animation: none; }
}

/* HEADLINE — the moment */
.big {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: clamp(48px, 9.5vw, 132px);
  line-height: 0.96;
  letter-spacing: -0.035em;
  color: var(--text-primary);
  margin-bottom: var(--space-3xl);
}
.big .line {
  display: block;
}
.big .line.two {
  color: var(--text-tertiary);
}

/* LEAD — single dense sentence below headline */
.lead {
  font: 400 18px/1.55 var(--font-body);
  color: var(--text-secondary);
  max-width: 56ch;
  margin-bottom: var(--space-3xl);
}

/* ACTIONS — primary button + text link */
.actions {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  flex-wrap: wrap;
}
.textlink {
  color: var(--text-secondary);
  font-size: 13px;
  text-decoration: none;
  transition: color var(--dur-snap) var(--ease-standard);
}
.textlink:hover { color: var(--text-primary); }

/* BOTTOM PROOF ROW — three privacy marks in mono */
.proof {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--text-secondary);
  font-size: 11px;
}
.proof .mark {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent-primary);
}
.proof.tail { margin-left: auto; }

/* Responsive ──────────────────────────────────────── */
@media (max-width: 768px) {
  .strip-inner .rec { margin-left: 0; }
  .proof.tail { margin-left: 0; }
  .lead { font-size: 16px; }
  .ticker { font-size: 10.5px; }
}
</style>

<script>
// Ticker cycles through a small set of realistic event lines every ~3.5s.
// Pure data — no fake values, just illustrative event shapes.
const events = [
  { t: '10:42', app: 'Xcode',        sep: '→', text: 'SessionAggregator.swift' },
  { t: '10:43', app: 'Linear',       sep: '→', text: 'LEA-431 ▸ In Review' },
  { t: '10:44', app: 'Claude Code',  sep: '→', text: 'session 4f2a · 2 tool calls' },
  { t: '10:46', app: 'GitHub',       sep: '→', text: 'feature/track-5 · pushed 3 commits' },
  { t: '10:51', app: 'Slack',        sep: '→', text: '#frontend · reaction' },
  { t: '10:57', app: 'Calendar',     sep: '→', text: 'design review · in 8 min' },
];
const row = document.getElementById('tickerRow');
const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
if (row && !reduceMotion) {
  let i = 0;
  setInterval(() => {
    i = (i + 1) % events.length;
    const e = events[i];
    row.style.opacity = '0';
    setTimeout(() => {
      row.innerHTML = `<span class="t-time">${e.t}</span><span class="t-app">${e.app}</span><span class="t-sep">${e.sep}</span><span class="t-text">${e.text}</span>`;
      row.style.opacity = '1';
    }, 220);
  }, 3500);
  // smooth opacity transitions
  row.style.transition = 'opacity 200ms ease';
}
</script>
