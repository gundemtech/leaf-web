---
import LeafButton from '../LeafButton.astro';
---
<section class="hero">
  <div class="top-strip">
    <div class="wrap strip-inner">
      <span class="mono">leaf</span>
      <span class="sep">·</span>
      <span class="mono">the shared brain for engineering orgs</span>
      <span class="sep">·</span>
      <span class="mono dim">v1.0.0-alpha.15</span>
      <span class="rec"><span class="rec-dot"></span><span class="mono dim">capturing</span></span>
    </div>
  </div>

  <div class="wrap hero-body">
    <div class="ticker mono" aria-hidden="true">
      <div class="ticker-stage" id="tickerStage">
        <div class="t-row">
          <span class="t-time">10:42</span>
          <span class="t-app">Xcode</span>
          <span class="t-sep">→</span>
          <span class="t-text">SessionAggregator.swift</span>
        </div>
      </div>
    </div>

    <h1 class="big">
      <span class="line one">One shared <span class="morph-word" id="morphWord" aria-label="brain — also leaf">brain</span>.</span>
      <span class="line two">For your whole team.</span>
    </h1>

    <p class="lead">
      Captured automatically across Linear, GitHub, Slack, and the Mac.
      Encrypted locally, surfaced only on each person's terms — no standups,
      no manager-side surveillance, no screen recording.
    </p>

    <div class="actions">
      <LeafButton variant="primary" size="lg" href="/signup">Install for macOS →</LeafButton>
      <a class="textlink mono" href="https://leaf-docs.gundem.tech" target="_blank" rel="noopener">read the whitepaper ↗</a>
    </div>
  </div>

  <div class="bottom-strip">
    <div class="wrap strip-inner">
      <span class="proof"><span class="mark"></span><span class="mono">default share — nothing</span></span>
      <span class="proof"><span class="mark"></span><span class="mono">never leaves your Mac unencrypted</span></span>
      <span class="proof"><span class="mark"></span><span class="mono">admin has no override</span></span>
      <span class="proof tail"><span class="mono dim">open source · MIT</span></span>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 56px); /* full viewport minus nav */
}

/* TOP / BOTTOM hairline strips ──────────────────────── */
.top-strip {
  border-bottom: 1px solid var(--border-subtle);
  background: color-mix(in srgb, var(--surface-canvas) 70%, transparent);
}
.bottom-strip {
  border-top: 1px solid var(--border-subtle);
  margin-top: auto;
}
.strip-inner {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
  font-size: 11px;
  color: var(--text-tertiary);
  flex-wrap: wrap;
}
.strip-inner .sep { color: var(--text-quaternary); }
.strip-inner .dim { color: var(--text-quaternary); }
.rec {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.rec-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--accent-primary);
  animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(0.8); }
}
@media (prefers-reduced-motion: reduce) {
  .rec-dot { animation: none; }
}

/* HERO BODY ────────────────────────────────────────── */
.hero-body {
  display: flex;
  flex-direction: column;
  flex: 1;
  justify-content: center;
  padding-top: var(--space-5xl);
  padding-bottom: var(--space-5xl);
}

/* TICKER — vertical conveyor with soft gradient mask top/bottom */
.ticker {
  position: relative;
  height: 44px;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  font-size: 11.5px;
  color: var(--text-tertiary);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 38%, black 62%, transparent 100%);
          mask-image: linear-gradient(to bottom, transparent 0%, black 38%, black 62%, transparent 100%);
}
.ticker-stage {
  position: relative;
  width: 100%;
  height: 100%;
}
.t-row {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  white-space: nowrap;
  will-change: transform, opacity;
}
.t-time { color: var(--text-quaternary); }
.t-app { color: var(--text-primary); }
.t-sep { color: var(--text-quaternary); }
.t-text { color: var(--text-secondary); }

@media (prefers-reduced-motion: reduce) {
  .ticker { -webkit-mask-image: none; mask-image: none; }
}

/* HEADLINE — the moment */
.big {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: clamp(44px, 7.5vw, 104px);
  line-height: 1.02;
  letter-spacing: -0.035em;
  color: var(--text-primary);
  margin-bottom: var(--space-3xl);
}
.big .line {
  display: block;
}
.big .line.two {
  color: var(--text-tertiary);
}

/* Word that cycles between "brain" and "leaf" — letter scramble + color morph */
.morph-word {
  display: inline-block;
  color: var(--text-primary);
  transition: color 850ms cubic-bezier(.4, 0, .2, 1),
              text-shadow 850ms cubic-bezier(.4, 0, .2, 1);
  transform-origin: center 60%;
  will-change: transform, color;
  white-space: nowrap;
}
.morph-word.is-leaf {
  color: var(--accent-primary);
  text-shadow:
    0 0 26px color-mix(in srgb, var(--accent-primary) 20%, transparent),
    0 0 70px color-mix(in srgb, var(--accent-primary) 10%, transparent);
}
@media (prefers-reduced-motion: reduce) {
  .morph-word { transition: none; text-shadow: none; }
  .morph-word.is-leaf { text-shadow: none; }
}

/* LEAD — single dense sentence below headline */
.lead {
  font: 400 18px/1.55 var(--font-body);
  color: var(--text-secondary);
  max-width: 56ch;
  margin-bottom: var(--space-3xl);
}

/* ACTIONS — primary button + text link */
.actions {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  flex-wrap: wrap;
}
.textlink {
  color: var(--text-secondary);
  font-size: 13px;
  text-decoration: none;
  transition: color var(--dur-snap) var(--ease-standard);
}
.textlink:hover { color: var(--text-primary); }

/* BOTTOM PROOF ROW — three privacy marks in mono */
.proof {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--text-secondary);
  font-size: 11px;
}
.proof .mark {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent-primary);
}
.proof.tail { margin-left: auto; }

/* Responsive ──────────────────────────────────────── */
@media (max-width: 768px) {
  .strip-inner .rec { margin-left: 0; }
  .proof.tail { margin-left: 0; }
  .lead { font-size: 16px; }
  .ticker { font-size: 10.5px; }
}
</style>

<script>
// Vertical conveyor: outgoing row slides down through the bottom gradient
// while the incoming row slides in from above the top gradient.
const events = [
  { t: '10:42', app: 'Xcode',        sep: '→', text: 'SessionAggregator.swift' },
  { t: '10:43', app: 'Linear',       sep: '→', text: 'LEA-431 ▸ In Review' },
  { t: '10:44', app: 'Claude Code',  sep: '→', text: 'session 4f2a · 2 tool calls' },
  { t: '10:46', app: 'GitHub',       sep: '→', text: 'feature/track-5 · pushed 3 commits' },
  { t: '10:51', app: 'Slack',        sep: '→', text: '#frontend · reaction' },
  { t: '10:57', app: 'Calendar',     sep: '→', text: 'design review · in 8 min' },
];
const stage = document.getElementById('tickerStage');
const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// Clone the template row from the DOM — preserves Astro's data-astro-cid-*
// attribute so scoped CSS (display: flex, gap, span colors) keeps applying.
const templateRow = stage?.querySelector<HTMLDivElement>('.t-row');
function buildRow(e: typeof events[number]): HTMLDivElement {
  const div = templateRow!.cloneNode(true) as HTMLDivElement;
  div.querySelector('.t-time')!.textContent = e.t;
  div.querySelector('.t-app')!.textContent = e.app;
  div.querySelector('.t-sep')!.textContent = e.sep;
  div.querySelector('.t-text')!.textContent = e.text;
  div.style.transform = '';
  div.style.opacity = '';
  return div;
}

if (stage && templateRow && !reduceMotion) {
  const DURATION = 1100;
  const EASE = 'cubic-bezier(.7, 0, .25, 1)';
  const INTERVAL = 3200;
  let idx = 0;
  let busy = false;

  const cycle = () => {
    if (busy) return;
    busy = true;
    const prev = idx;
    idx = (idx + 1) % events.length;

    const outgoing = buildRow(events[prev]);
    const incoming = buildRow(events[idx]);
    stage.replaceChildren(outgoing, incoming);

    outgoing.animate(
      [
        { transform: 'translateY(0)',    opacity: 1 },
        { transform: 'translateY(100%)', opacity: 0 },
      ],
      { duration: DURATION, easing: EASE, fill: 'forwards' },
    );

    const inAnim = incoming.animate(
      [
        { transform: 'translateY(-100%)', opacity: 0 },
        { transform: 'translateY(0)',     opacity: 1 },
      ],
      { duration: DURATION, easing: EASE, fill: 'forwards' },
    );
    inAnim.onfinish = () => {
      outgoing.remove();
      busy = false;
    };
  };

  setInterval(cycle, INTERVAL);
}

// ─── Headline word morph: "brain" ⇄ "leaf" every 1.5s ─────────────
// Letter-by-letter scramble through random chars, staggered per position,
// plus color crossfade to accent-green and a snappy squish-stretch pulse.
const morphEl = document.getElementById('morphWord');
const morphWords = ['brain', 'leaf'];
const SCRAMBLE_CHARS = 'abcdefghijklmnopqrstuvwxyz';

function scrambleMorph(el: HTMLElement, from: string, to: string): void {
  const len = Math.max(from.length, to.length);
  const STAGGER = 110;
  const SCRAMBLE_DUR = 460;
  const start = performance.now();

  const slots = Array.from({ length: len }, (_, i) => ({
    from: from[i] ?? '',
    to: to[i] ?? '',
    lockAt: i * STAGGER + SCRAMBLE_DUR,
  }));

  const tick = (now: number) => {
    const t = now - start;
    let out = '';
    let allDone = true;
    for (const s of slots) {
      if (t >= s.lockAt) {
        out += s.to;
      } else if (t >= s.lockAt - SCRAMBLE_DUR) {
        allDone = false;
        out += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
      } else {
        allDone = false;
        out += s.from;
      }
    }
    el.textContent = out;
    if (!allDone) {
      requestAnimationFrame(tick);
    } else {
      el.textContent = to;
    }
  };
  requestAnimationFrame(tick);
}

if (morphEl && !reduceMotion) {
  let mi = 0;
  setInterval(() => {
    const from = morphWords[mi];
    mi = (mi + 1) % morphWords.length;
    const to = morphWords[mi];
    morphEl.classList.toggle('is-leaf');
    scrambleMorph(morphEl, from, to);
    morphEl.animate(
      [
        { transform: 'scale(1) rotate(0deg)',         offset: 0 },
        { transform: 'scale(0.98) rotate(-0.5deg)',   offset: 0.30 },
        { transform: 'scale(1.025) rotate(0.4deg)',   offset: 0.65 },
        { transform: 'scale(1) rotate(0deg)',         offset: 1 },
      ],
      { duration: 1100, easing: 'cubic-bezier(.4, 0, .2, 1)' },
    );
  }, 2800);
}
</script>
