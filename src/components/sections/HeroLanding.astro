---
import LeafButton from '../LeafButton.astro';
---
<section class="hero">
  <div class="wrap hero-body">
    <div class="hero-text" data-reveal>
      <div class="ticker mono" aria-hidden="true">
        <div class="ticker-stage" id="tickerStage">
          <div class="t-row">
            <span class="t-time">10:42</span>
            <span class="t-app">Xcode</span>
            <span class="t-sep">→</span>
            <span class="t-text">SessionAggregator.swift</span>
          </div>
        </div>
      </div>

      <h1 class="big">
        <span class="line one">One shared <span class="morph-word" id="morphWord" aria-label="brain, leaf, memory, mind, thread"><span class="m-slot is-in" data-word="brain">brain.</span><span class="m-slot is-waiting" data-word="leaf">leaf.</span><span class="m-slot is-waiting" data-word="memory">memory.</span><span class="m-slot is-waiting" data-word="mind">mind.</span><span class="m-slot is-waiting" data-word="thread">thread.</span></span></span>
        <span class="line two">For your whole team.</span>
      </h1>

      <p class="lead">
        Captured automatically from the tools your team already uses: trackers,
        code, chat, calendar, the Mac. Encrypted locally, surfaced only on each
        person's terms. No standups, no manager-side surveillance, no screen
        recording.
      </p>

      <div class="actions">
        <LeafButton variant="primary" size="lg" href="#waitlist" data-cta-waitlist>Join Waitlist →</LeafButton>
        <a class="textlink mono" href="https://leaf-docs.gundem.tech" target="_blank" rel="noopener">read the whitepaper ↗</a>
      </div>
    </div>

    <figure class="hero-art" aria-hidden="true" data-reveal>
      <img
        class="hero-art-main"
        src="/images/hero-app.png"
        alt=""
        loading="eager"
        decoding="async"
        width="2000"
        height="1250"
      />
      <img
        class="hero-art-popover"
        src="/images/hero-popover.png"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>

  <div class="bottom-strip">
    <div class="wrap strip-inner">
      <span class="mono">leaf</span>
      <span class="sep">·</span>
      <span class="mono">the shared brain for engineering orgs</span>
      <span class="sep">·</span>
      <span class="mono dim">v1.0.0-alpha.15</span>
      <span class="rec"><span class="rec-dot"></span></span>
      <span class="proof tail"><span class="mono dim">open source · MIT</span></span>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 56px); /* full viewport minus nav */
}

/* BOTTOM hairline strip — meta + capturing + license ──── */
.bottom-strip {
  border-top: 1px solid var(--border-subtle);
  margin-top: auto;
}
.strip-inner {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
  font-size: 11px;
  color: var(--text-tertiary);
  flex-wrap: wrap;
}
.strip-inner .sep { color: var(--text-quaternary); }
.strip-inner .dim { color: var(--text-quaternary); }
.rec {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.rec-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--accent-primary);
  animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(0.8); }
}
@media (prefers-reduced-motion: reduce) {
  .rec-dot { animation: none; }
}

/* HERO BODY ────────────────────────────────────────── */
.hero-body {
  display: grid;
  grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
  gap: var(--space-3xl);
  align-items: center;
  flex: 1;
  padding-top: var(--space-5xl);
  padding-bottom: var(--space-5xl);
}
.hero-text {
  display: flex;
  flex-direction: column;
}
.hero-art {
  margin: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-art-main {
  width: 100%;
  height: auto;
  max-width: 880px;
  display: block;
  animation: heroFloat 6.5s ease-in-out infinite;
  will-change: transform;
}
.hero-art-popover {
  position: absolute;
  top: 6%;
  right: -4%;
  width: 32%;
  max-width: 300px;
  height: auto;
  display: block;
  filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.6));
  animation: heroFloatPop 7.5s ease-in-out infinite;
  animation-delay: -2.2s; /* offset phase from main */
  will-change: transform;
  z-index: 1;
}
@keyframes heroFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}
@keyframes heroFloatPop {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-9px); }
}
@media (prefers-reduced-motion: reduce) {
  .hero-art-main, .hero-art-popover { animation: none; }
}
@media (max-width: 1000px) {
  .hero-art-popover { right: 0; width: 28%; }
}
@media (max-width: 640px) {
  .hero-art-popover { display: none; }
}

@media (max-width: 1000px) {
  .hero-body {
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
  }
  .hero-art { order: -1; }
  .hero-art img { max-width: 520px; }
}
@media (max-width: 640px) {
  .hero-art { display: none; }
}

/* TICKER — vertical conveyor with soft gradient mask top/bottom */
.ticker {
  position: relative;
  height: 44px;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  font-size: 11.5px;
  color: var(--text-tertiary);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 38%, black 62%, transparent 100%);
          mask-image: linear-gradient(to bottom, transparent 0%, black 38%, black 62%, transparent 100%);
}
.ticker-stage {
  position: relative;
  width: 100%;
  height: 100%;
}
.t-row {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  white-space: nowrap;
  will-change: transform, opacity;
}
.t-time { color: var(--text-quaternary); }
.t-app { color: var(--text-primary); }
.t-sep { color: var(--text-quaternary); }
.t-text { color: var(--text-secondary); }

@media (prefers-reduced-motion: reduce) {
  .ticker { -webkit-mask-image: none; mask-image: none; }
}

/* HEADLINE — the moment */
.big {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: clamp(34px, 4.7vw, 72px);
  line-height: 1.02;
  letter-spacing: -0.035em;
  color: var(--text-primary);
  margin-bottom: var(--space-3xl);
}
.big .line {
  display: block;
}
.big .line.two {
  color: var(--text-tertiary);
}

/* Word that cycles between "brain" and "leaf" — calm crossfade with drift.
   Two slots live in the same grid cell so the wrapper sizes to the wider
   word and surrounding text (the period) never shifts. */
.morph-word {
  display: inline-grid;
  vertical-align: baseline;
}
.m-slot {
  grid-area: 1 / 1;
  white-space: nowrap;
  will-change: opacity, transform;
}
/* Outgoing: fades out immediately, fully gone by 500ms.
   Incoming: delays 450ms so it only starts appearing after outgoing is ~95% gone.
   Result: ~50ms overlap window where both are near-invisible, no double-vision. */
.m-slot.is-in {
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity 500ms cubic-bezier(.4, 0, .2, 1) 450ms,
    transform 600ms cubic-bezier(.4, 0, .2, 1) 400ms;
}
.m-slot.is-out {
  opacity: 0;
  transform: translateY(-0.18em);
  transition:
    opacity 500ms cubic-bezier(.4, 0, .2, 1),
    transform 600ms cubic-bezier(.4, 0, .2, 1);
}
.m-slot.is-waiting {
  opacity: 0;
  transform: translateY(0.18em);
  transition: none;
  pointer-events: none;
}
.m-slot {
  color: var(--accent-primary);
  text-shadow: 0 0 28px color-mix(in srgb, var(--accent-primary) 14%, transparent);
}
@media (prefers-reduced-motion: reduce) {
  .m-slot { transition: none; text-shadow: none; }
}

/* LEAD — single dense sentence below headline */
.lead {
  font: 400 18px/1.55 var(--font-body);
  color: var(--text-secondary);
  max-width: 56ch;
  margin-bottom: var(--space-3xl);
}

/* ACTIONS — primary button + text link */
.actions {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  flex-wrap: wrap;
}
.textlink {
  color: var(--text-secondary);
  font-size: 13px;
  text-decoration: none;
  transition: color var(--dur-snap) var(--ease-standard);
}
.textlink:hover { color: var(--text-primary); }

/* BOTTOM PROOF ROW — three privacy marks in mono */
.proof {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--text-secondary);
  font-size: 11px;
}
.proof .mark {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent-primary);
}
.proof.tail { margin-left: auto; }

/* Responsive ──────────────────────────────────────── */
@media (max-width: 768px) {
  .strip-inner .rec { margin-left: 0; }
  .proof.tail { margin-left: 0; }
  .lead { font-size: 16px; }
  .ticker { font-size: 10.5px; }
}
</style>

<script>
// Vertical conveyor: outgoing row slides down through the bottom gradient
// while the incoming row slides in from above the top gradient.
const events = [
  { t: '10:42', app: 'Xcode',        sep: '→', text: 'SessionAggregator.swift' },
  { t: '10:43', app: 'Linear',       sep: '→', text: 'LEA-431 ▸ In Review' },
  { t: '10:44', app: 'Claude Code',  sep: '→', text: 'session 4f2a · 2 tool calls' },
  { t: '10:46', app: 'GitHub',       sep: '→', text: 'feature/track-5 · pushed 3 commits' },
  { t: '10:51', app: 'Slack',        sep: '→', text: '#frontend · reaction' },
  { t: '10:57', app: 'Calendar',     sep: '→', text: 'design review · in 8 min' },
];
const stage = document.getElementById('tickerStage');
const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// Clone the template row from the DOM — preserves Astro's data-astro-cid-*
// attribute so scoped CSS (display: flex, gap, span colors) keeps applying.
const templateRow = stage?.querySelector<HTMLDivElement>('.t-row');
function buildRow(e: typeof events[number]): HTMLDivElement {
  const div = templateRow!.cloneNode(true) as HTMLDivElement;
  div.querySelector('.t-time')!.textContent = e.t;
  div.querySelector('.t-app')!.textContent = e.app;
  div.querySelector('.t-sep')!.textContent = e.sep;
  div.querySelector('.t-text')!.textContent = e.text;
  div.style.transform = '';
  div.style.opacity = '';
  return div;
}

if (stage && templateRow && !reduceMotion) {
  const DURATION = 1100;
  const EASE = 'cubic-bezier(.7, 0, .25, 1)';
  const INTERVAL = 3200;
  let idx = 0;
  let busy = false;

  const cycle = () => {
    if (busy) return;
    busy = true;
    const prev = idx;
    idx = (idx + 1) % events.length;

    const outgoing = buildRow(events[prev]);
    const incoming = buildRow(events[idx]);
    stage.replaceChildren(outgoing, incoming);

    outgoing.animate(
      [
        { transform: 'translateY(0)',    opacity: 1 },
        { transform: 'translateY(100%)', opacity: 0 },
      ],
      { duration: DURATION, easing: EASE, fill: 'forwards' },
    );

    const inAnim = incoming.animate(
      [
        { transform: 'translateY(-100%)', opacity: 0 },
        { transform: 'translateY(0)',     opacity: 1 },
      ],
      { duration: DURATION, easing: EASE, fill: 'forwards' },
    );
    inAnim.onfinish = () => {
      outgoing.remove();
      busy = false;
    };
  };

  setInterval(cycle, INTERVAL);
}

// ─── Headline word morph: "brain" ⇄ "leaf" — calm crossfade ─────────────
// Two slots live in the same grid cell. On each tick: current slot fades up
// and out; next slot drifts in from below into place. No scramble, no bounce.
const morphEl = document.getElementById('morphWord');
const slots = morphEl ? Array.from(morphEl.querySelectorAll<HTMLElement>('.m-slot')) : [];
if (morphEl && slots.length >= 2 && !reduceMotion) {
  let activeIdx = 0;
  const CYCLE = 3000;
  // Outgoing finishes by ~600ms, incoming finishes by ~950ms.
  // Reset outgoing to waiting only after incoming has fully landed.
  const SETTLE = 1050;
  setInterval(() => {
    const outgoing = slots[activeIdx];
    activeIdx = (activeIdx + 1) % slots.length;
    const incoming = slots[activeIdx];

    outgoing.classList.replace('is-in', 'is-out');
    incoming.classList.replace('is-waiting', 'is-in');

    setTimeout(() => {
      outgoing.classList.replace('is-out', 'is-waiting');
    }, SETTLE);
  }, CYCLE);
}
</script>
