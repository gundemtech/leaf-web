---
import LeafCard from '../LeafCard.astro';
import LeafEyebrow from '../LeafEyebrow.astro';
const cards = [
  { icon: 'app-dashed', title: 'App usage', desc: 'Which app you focus on, and for how long.' },
  { icon: 'git-branch', title: 'Git activity', desc: 'Commits and PR activity in watched repos.' },
  { icon: 'sparkles', title: 'AI tools', desc: 'Claude Code, Cursor, Windsurf — file + tool metadata.' },
  { icon: 'calendar', title: 'Calendar', desc: 'Meetings, focus blocks, attendee counts.' },
  { icon: 'moon-zzz', title: 'Focus state', desc: 'macOS Focus modes, idle, sleep/wake.' },
  { icon: 'folder', title: 'File touches', desc: 'Files changed in folders you opt in to.' },
];
---
<section id="capture" class="layer-a">
  <div class="wrap">
    <LeafEyebrow number="01" label="ON YOUR MAC" />
    <h2 class="t-display">Captured automatically.<br /><span class="muted">Nothing leaves your laptop unencrypted.</span></h2>

    <div class="grid">
      {cards.map(c => (
        <LeafCard variant="raised" padding="generous" interactive>
          <div class="card-icon">
            <svg width="24" height="24" style="color: var(--accent-primary)"><use href={`/assets/icons/sprite.svg#${c.icon}`} /></svg>
          </div>
          <h3 class="t-title-sm">{c.title}</h3>
          <p class="t-body-sm desc">{c.desc}</p>
        </LeafCard>
      ))}
    </div>

    <p class="footnote t-body-sm">
      Metadata only — never file contents, keystrokes, or screenshots.
      <a href="/privacy">Read privacy details →</a>
    </p>
  </div>
</section>

<style>
.layer-a { padding: var(--space-5xl) 0; }
.layer-a h2 { margin: var(--space-md) 0 var(--space-3xl); max-width: 22ch; }
.muted { color: var(--text-secondary); }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
@media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
.card-icon { margin-bottom: var(--space-md); }
.desc { color: var(--text-secondary); margin-top: var(--space-xs); }
.footnote { margin-top: var(--space-xl); color: var(--text-tertiary); }
.footnote a { color: var(--accent-primary); }
.footnote a:hover { text-decoration: underline; }
</style>
