---
import LeafEyebrow from '../LeafEyebrow.astro';
import LeafButton from '../LeafButton.astro';
const points = [
  { title: 'Local-first storage', desc: 'SQLCipher AES-256, key in macOS Keychain. Never leaves your Mac unencrypted.' },
  { title: 'End-to-end encryption', desc: 'Team data wrapped with X25519 + XChaCha20-Poly1305. Relay sees only ciphertext.' },
  { title: 'Share Controls', desc: 'Pick per-app what\'s visible to teammates. Default: nothing. Admin can\'t override.' },
];
---
<section id="privacy-teaser" class="privacy">
  <div class="wrap">
    <LeafEyebrow number="05" label="PRIVATE BY ARCHITECTURE" />
    <h2 class="t-display-lg">Your manager can't peek<br /><span class="accent">without your permission.</span></h2>

    <ul class="points">
      {points.map(p => (
        <li>
          <span class="dot" aria-hidden="true"></span>
          <div>
            <h3 class="t-title-sm">{p.title}</h3>
            <p class="t-body muted">{p.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="ctas">
      <LeafButton variant="secondary" href="/privacy">How privacy works →</LeafButton>
      <LeafButton variant="ghost" href="/open-source">Open-source verifiability →</LeafButton>
    </div>
  </div>
</section>

<style>
.privacy { padding: var(--space-5xl) 0; }
.privacy h2 { margin: var(--space-md) 0 var(--space-3xl); max-width: 22ch; }
.points { display: flex; flex-direction: column; gap: var(--space-xl); margin-bottom: var(--space-xl); max-width: 60ch; }
.points li { display: flex; gap: var(--space-md); }
.dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-primary); margin-top: 10px; flex-shrink: 0; }
.points h3 { margin-bottom: var(--space-xs); }
.muted { color: var(--text-secondary); }
.ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
</style>
