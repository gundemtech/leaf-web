---
import LeafButton from '../LeafButton.astro';
import LeafInput from '../LeafInput.astro';
---
<section id="waitlist" class="waitlist">
  <div class="wrap">
    <!-- thin stats strip at the very top, hairline only.
         data-count* values are last-known-good fallbacks used until the live
         RPC settles (or if it fails). Live numbers come from waitlist-stats.ts. -->
    <div class="waitlist-stats" data-stats data-reveal>
      <span class="stat">
        <span class="stat-dot"></span>
        <span class="stat-num mono" data-count-total data-count="312">0</span>
        <span class="stat-label mono">leafs already in line</span>
      </span>
      <span class="stat-week-block" data-stat-week>
        <span class="stat-sep mono" aria-hidden="true">·</span>
        <span class="stat">
          <span class="stat-num mono" data-count-week data-count="47">0</span>
          <span class="stat-label mono">joined this week</span>
        </span>
      </span>
      <span class="stat-viewing-block" data-stat-viewing>
        <span class="stat-sep mono" aria-hidden="true">·</span>
        <span class="stat">
          <span class="stat-num mono" data-count-viewing data-count="1">0</span>
          <span class="stat-label mono">viewing now</span>
        </span>
      </span>
      <span class="stat tail mono">v1 ships when we're sure it's ready</span>
    </div>

    <div class="waitlist-grid">
      <div class="waitlist-text" data-reveal>
        <p class="waitlist-eyebrow mono">WAITLIST</p>
        <h2 class="waitlist-headline">Be there when v1 ships.</h2>
        <p class="waitlist-sub">
          Drop your email. We'll ping you once, when v1 lands.
          No newsletter, no drip, no marketing.
        </p>
      </div>

      <div class="waitlist-action" data-reveal>
        <form id="waitlist-form" class="waitlist-form">
          <LeafInput type="email" name="email" placeholder="you@email.com" required autocomplete="email" />
          <input type="text" name="hp" class="honeypot" tabindex="-1" autocomplete="off" />
          <div class="cf-turnstile" data-sitekey="0x4AAAAAADCjktFBs6RTYJTZ"></div>
          <LeafButton type="submit" variant="primary">Put me on it →</LeafButton>
        </form>

        <!-- Success card — revealed in place of the form on a 200 OK (waitlist.ts).
             Mirrors the OAuth browser success page (LoopbackCallbackListener) on
             leaf-web tokens: green check badge, rise + pop, draw-on checkmark. -->
        <div class="waitlist-success" data-waitlist-success hidden role="status" aria-live="polite" tabindex="-1">
          <div class="ws-badge">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.6l4.3 4.3L19 7.2"/></svg>
          </div>
          <h3 class="ws-title">You're on the list.</h3>
          <p class="ws-sub">We'll email you once — the day v1 lands. Nothing else.</p>
        </div>
      </div>
    </div>

    <p class="status t-body-sm" data-status></p>
  </div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  import '../../scripts/waitlist';
</script>

<script>
  // CTAs marked with [data-cta-waitlist] (or any link to #waitlist) auto-focus
  // the email input after the smooth-scroll finishes, so the user can type immediately.
  // Also briefly highlight the card so it's clear they landed there.
  const waitlistCtas = document.querySelectorAll<HTMLAnchorElement>('a[href="#waitlist"], a[href="/#waitlist"], [data-cta-waitlist]');
  waitlistCtas.forEach(a => {
    a.addEventListener('click', (e) => {
      const card = document.getElementById('waitlist');
      const input = card?.querySelector<HTMLInputElement>('input[type="email"]');
      if (!card) return;
      // Only intercept same-page anchor; cross-page link (/#waitlist) lets browser navigate.
      const href = a.getAttribute('href');
      if (href === '#waitlist') {
        e.preventDefault();
        card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        card.classList.remove('cta-flash');
        // force reflow then re-add for re-trigger
        void card.offsetWidth;
        card.classList.add('cta-flash');
        setTimeout(() => input?.focus({ preventScroll: true }), 700);
      }
    });
  });
  // If we arrive with #waitlist in the URL (cross-page nav), also focus the input.
  if (location.hash === '#waitlist') {
    setTimeout(() => {
      const input = document.querySelector<HTMLInputElement>('#waitlist input[type="email"]');
      input?.focus({ preventScroll: true });
      document.getElementById('waitlist')?.classList.add('cta-flash');
    }, 500);
  }
</script>

<script>
  // Live counter — fetch + IntersectionObserver count-up + polling.
  // See src/scripts/waitlist-stats.ts for the full flow.
  import '../../scripts/waitlist-stats';
</script>

<style>
.waitlist {
  padding: var(--space-5xl) 0;
  border-top: 1px solid var(--border-subtle);
}
.waitlist.cta-flash .waitlist-form :global(input[type="email"]) {
  animation: waitlistFlash 1600ms ease-out 1;
}
@keyframes waitlistFlash {
  0%   { box-shadow: 0 0 0 0   color-mix(in srgb, var(--accent-primary) 0%,  transparent); }
  20%  { box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent-primary) 40%, transparent), 0 0 40px color-mix(in srgb, var(--accent-primary) 35%, transparent); }
  100% { box-shadow: 0 0 0 0   color-mix(in srgb, var(--accent-primary) 0%,  transparent); }
}
@media (prefers-reduced-motion: reduce) {
  .waitlist.cta-flash .waitlist-form :global(input[type="email"]) { animation: none; }
}

/* ─────────── thin stats strip ─────────── */
.waitlist-stats {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  flex-wrap: wrap;
  padding: 0 0 var(--space-lg);
  margin-bottom: var(--space-4xl);
  border-bottom: 1px solid var(--border-subtle);
  font: 500 11px/1 var(--font-mono);
  letter-spacing: 0.06em;
  color: var(--text-tertiary);
}
.stat { display: inline-flex; align-items: center; gap: 6px; }
/* Sub-blocks group their leading separator with the stat so the whole
   segment collapses cleanly when hidden (this_week=0 case). */
.stat-week-block:not([hidden]),
.stat-viewing-block:not([hidden]) {
  display: inline-flex;
  align-items: center;
  gap: var(--space-md);
}
.stat-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--accent-primary);
  box-shadow: 0 0 10px color-mix(in srgb, var(--accent-primary) 70%, transparent);
  animation: statsPulse 2.4s ease-in-out infinite;
}
@keyframes statsPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.5; transform: scale(0.8); }
}
.stat-num {
  color: var(--text-primary);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  font-size: 13px;
}
.stat-label { color: var(--text-tertiary); }
.stat-sep   { color: var(--text-quaternary); }
.stat.tail  { margin-left: auto; color: var(--text-quaternary); }

/* ─────────── body grid — no card, no background ─────────── */
.waitlist-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
  gap: var(--space-4xl);
  align-items: end;
}

.waitlist-eyebrow {
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-primary);
  margin: 0 0 var(--space-md);
}
.waitlist-headline {
  font: 600 clamp(36px, 4.4vw, 64px) / 1.1 var(--font-body);
  letter-spacing: -0.022em;
  color: var(--text-primary);
  margin: 0 0 var(--space-md);
  max-width: 14ch;
}
.waitlist-sub {
  font: 400 17px/1.55 var(--font-body);
  color: var(--text-secondary);
  margin: 0;
  max-width: 50ch;
}

.waitlist-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  width: 100%;
}
.waitlist-form :global(input[type="email"]) {
  width: 100%;
  transition: box-shadow 200ms var(--ease-standard), border-color 200ms var(--ease-standard);
}
.waitlist-form :global(input[type="email"]:focus),
.waitlist-form :global(input[type="email"]:focus-visible) {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow:
    0 0 0 3px color-mix(in srgb, var(--accent-primary) 22%, transparent),
    0 0 24px color-mix(in srgb, var(--accent-primary) 18%, transparent);
}
.waitlist-form :global(.btn) { width: 100%; justify-content: center; }
.honeypot { display: none; }

/* ─────────── action column: form ⇄ success card ─────────── */
.waitlist-action { width: 100%; }
/* `.waitlist-form { display: flex }` would otherwise beat the UA [hidden]
   rule, so the form must be collapsed explicitly when swapped out. */
.waitlist-form[hidden] { display: none; }

/* Success card — visual language mirrors the app's OAuth browser page. */
.waitlist-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-md);
  width: 100%;
  padding: var(--space-xl) var(--space-xl) calc(var(--space-xl) + 4px);
  background: var(--surface-raised);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  box-shadow: var(--elev-floating);
  animation: wsRise 450ms var(--ease-emphasized) both;
}
/* Higher specificity than the base rule so [hidden] still collapses it. */
.waitlist-success[hidden] { display: none; }
.waitlist-success:focus { outline: none; }

.ws-badge {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: color-mix(in srgb, var(--status-success) 16%, transparent);
  animation: wsPop 550ms 80ms cubic-bezier(.18, .89, .32, 1.28) both;
}
.ws-badge svg {
  width: 30px;
  height: 30px;
  fill: none;
  stroke: var(--status-success);
  stroke-width: 2.6;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.ws-badge svg path {
  stroke-dasharray: 22;
  stroke-dashoffset: 22;
  animation: wsDraw 400ms 360ms var(--ease-standard) forwards;
}
.ws-title {
  font: 600 21px/1.3 var(--font-body);
  letter-spacing: -0.012em;
  color: var(--text-primary);
  margin: 0;
}
.ws-sub {
  font: 400 15px/1.55 var(--font-body);
  color: var(--text-secondary);
  margin: 0;
  max-width: 34ch;
}

@keyframes wsRise {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: none; }
}
@keyframes wsPop {
  0%   { transform: scale(.6); opacity: 0; }
  60%  { transform: scale(1.06); }
  100% { transform: scale(1); }
}
@keyframes wsDraw {
  to { stroke-dashoffset: 0; }
}
@media (prefers-reduced-motion: reduce) {
  .waitlist-success { animation: none; }
  .ws-badge { animation: none; }
  .ws-badge svg path { animation: none; stroke-dashoffset: 0; }
}

.status {
  text-align: center;
  margin-top: var(--space-lg);
  color: var(--text-tertiary);
}
.status[data-state="success"] { color: var(--status-success); }
.status[data-state="error"]   { color: var(--status-danger); }

@media (prefers-reduced-motion: reduce) {
  .stat-dot { animation: none; }
}

@media (max-width: 900px) {
  .waitlist-stats .stat.tail { margin-left: 0; flex-basis: 100%; }
  .waitlist-grid {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }
  .waitlist-headline { max-width: none; }
}
</style>
