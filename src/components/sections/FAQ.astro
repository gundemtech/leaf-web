---
import LeafAccordion from '../LeafAccordion.astro';
import LeafEyebrow from '../LeafEyebrow.astro';
import LeafButton from '../LeafButton.astro';
const faqs = [
  { q: 'Is my code or messages captured?', a: 'No. Leaf captures only metadata — file paths, commit hashes, event timestamps. Never file contents, message bodies, or prompt-response text.' },
  { q: 'Can my manager see what apps I use?', a: 'Only if you explicitly add an app to your share list. Default = nothing shared. Admin role has no privileged read access.' },
  { q: 'Does Leaf work offline?', a: 'Yes. All capture and queries are local. Team sync requires internet, but core functionality works fully offline.' },
  { q: 'How is this different from RescueTime / WakaTime?', a: 'RescueTime tracks productivity scores. Leaf builds a queryable memory layer for AI tools — different goal, no productivity grading.' },
  { q: 'iOS / Windows / Linux?', a: 'macOS first. iOS planned post-MVP. Windows/Linux not on roadmap.' },
  { q: 'Is Leaf really open source?', a: 'Capture daemon, storage layer, MCP server, and crypto code are open. Hosted relay and Slack bot service are closed. See /open-source for the full matrix.' },
  { q: 'Can I run my own relay?', a: 'Enterprise plan ships with self-hosted relay. Other plans use our Cloudflare relay (untrusted by design — sees ciphertext only).' },
  { q: 'How does cancellation work?', a: 'Cancel anytime in /dashboard. Solo / Mac captures keep working forever (open source). Team sync stops at end of billing period.' },
];
---
<section id="faq" class="faq">
  <div class="wrap-narrow">
    <LeafEyebrow number="07" label="QUESTIONS" />
    <h2 class="t-display">Common questions.</h2>

    <div class="list">
      {faqs.map(f => (
        <LeafAccordion question={f.q}>{f.a}</LeafAccordion>
      ))}
    </div>

    <div class="cta">
      <LeafButton variant="ghost" href="https://leaf-docs.gundem.tech/faqs" external>Full FAQ in docs ↗</LeafButton>
    </div>
  </div>
</section>

<style>
.faq { padding: var(--space-5xl) 0; }
.faq h2 { margin: var(--space-md) 0 var(--space-xl); }
.cta { margin-top: var(--space-xl); text-align: center; }
</style>
