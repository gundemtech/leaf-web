---
import LeafEyebrow from '../LeafEyebrow.astro';

const rows = [
  {
    source: 'Issue trackers',
    examples: 'Linear, Jira',
    read: 'status changes, your comments, tickets you created',
    never: 'comment & ticket bodies',
    control: 'per-event toggle',
  },
  {
    source: 'Code',
    examples: 'GitHub, GitLab',
    read: 'your commits, PRs, reviews',
    never: 'source code, comment bodies',
    control: 'per-repo whitelist',
  },
  {
    source: 'Team chat',
    examples: 'Slack, Discord',
    read: 'your presence, your reactions, channels you authored in',
    never: 'message bodies, DMs',
    control: 'per-channel toggle',
  },
  {
    source: 'macOS apps',
    examples: 'Xcode, Figma, anything',
    read: 'frontmost app, idle state, window title',
    never: 'screen, keystrokes, app contents',
    control: 'per-app whitelist',
  },
  {
    source: 'AI tools',
    examples: 'Claude Code, Cursor',
    read: 'tool calls, file attribution, session timing',
    never: 'prompts, responses',
    control: 'per-tool toggle',
  },
  {
    source: 'Calendar',
    examples: 'Google, Outlook',
    read: '"in a meeting" boolean',
    never: 'titles, attendees, agendas',
    control: 'on / off',
  },
];
---
<section id="integrations" class="rdr">
  <div class="wrap">
    <div data-reveal><LeafEyebrow label="WHAT LEAF SEES" /></div>
    <h2 class="big" data-reveal>
      Most tools have a privacy policy.<br />
      <span class="dim">We have a list of things we can't read.</span>
    </h2>
    <p class="sub" data-reveal>
      Three columns, six sources, one rule per row: the workflow signals Leaf
      reads to understand your week, the content it will never touch, and what
      you alone decide to share with the team.
    </p>

    <div class="table" role="table" aria-label="What Leaf reads, never reads, and what you control per source">
      <div class="row row-head" role="row" data-rowidx="0">
        <span class="cell c-src" role="columnheader">Source</span>
        <span class="cell c-read" role="columnheader">Reads</span>
        <span class="cell c-never" role="columnheader">Never reads</span>
        <span class="cell c-share" role="columnheader">You control</span>
      </div>

      {rows.map((r, i) => (
        <div class="row" role="row" data-rowidx={i + 1}>
          <div class="cell c-src" role="cell">
            <span class="src-name">{r.source}</span>
            <span class="src-ex mono">{r.examples}</span>
          </div>
          <div class="cell c-read" role="cell">
            <span class="check">✓</span><span>{r.read}</span>
          </div>
          <div class="cell c-never" role="cell">
            <span class="ex">×</span><span class="strike">{r.never}</span>
          </div>
          <div class="cell c-share" role="cell">
            <span class="dot"></span><span>{r.control}</span>
          </div>
        </div>
      ))}

      <div class="row row-foot" role="row" data-rowidx="7">
        <div class="cell c-src" role="cell">
          <span class="src-name">… and more</span>
          <span class="src-ex mono">connector list grows</span>
        </div>
        <div class="cell cell-merge" role="cell">
          Each new connector ships with its own row in this table. Same three
          questions, asked publicly: what we read, what we refuse, what you control.
        </div>
      </div>
    </div>

    <div class="commitments">
      <p class="commitments-label mono" data-reveal>Four architectural commitments below the table.</p>
      <ul class="commit-grid">
        <li class="commit">
          <span class="commit-mark"></span>
          <p class="commit-title">Default share: nothing.</p>
          <p class="commit-desc">When you install Leaf, your team sees zero events. You opt in row by row.</p>
        </li>
        <li class="commit">
          <span class="commit-mark"></span>
          <p class="commit-title">Encrypted on your Mac.</p>
          <p class="commit-desc">The key lives in your Keychain. Never on a server. Lose the key, the data is unrecoverable.</p>
        </li>
        <li class="commit">
          <span class="commit-mark"></span>
          <p class="commit-title">Untrusted relay.</p>
          <p class="commit-desc">Team data flows through a relay that only sees ciphertext. Even we can't decrypt it.</p>
        </li>
        <li class="commit">
          <span class="commit-mark"></span>
          <p class="commit-title">No admin override.</p>
          <p class="commit-desc">There is no setting to give one, and there will not be. Symmetric visibility by design.</p>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
.rdr {
  padding: var(--space-5xl) 0;
  border-top: 1px solid var(--border-subtle);
}
.big {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: clamp(28px, 4.2vw, 56px);
  line-height: 1.15;
  letter-spacing: -0.025em;
  color: var(--text-primary);
  margin: var(--space-lg) 0 var(--space-lg);
}
.big .dim { color: var(--text-tertiary); }
.sub {
  max-width: 72ch;
  font: 400 17px/1.55 var(--font-body);
  color: var(--text-secondary);
  margin: 0 0 var(--space-4xl);
}

/* ─────────── TABLE — full-width grid ─────────── */
.table {
  display: grid;
  grid-template-columns: minmax(180px, 1.1fr) minmax(0, 2.4fr) minmax(0, 2.2fr) minmax(0, 1.6fr);
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
}
.row { display: contents; }

.cell {
  padding: var(--space-md) var(--space-md);
  border-bottom: 1px solid var(--border-subtle);
  font: 400 14px/1.55 var(--font-body);
  display: flex;
  gap: var(--space-sm);
  align-items: baseline;
  opacity: 0;
  transform: perspective(1100px) rotateX(-18deg) translateY(32px) scale(0.94);
  transform-origin: 50% 100%;
  transition:
    opacity 620ms var(--ease-standard),
    transform 620ms cubic-bezier(.16, .85, .35, 1);
}
.table.is-in .cell { opacity: 1; transform: perspective(1100px) rotateX(0) translateY(0) scale(1); }
.table.is-in [data-rowidx="0"] .cell { transition-delay: 0ms; }
.table.is-in [data-rowidx="1"] .cell { transition-delay: 80ms; }
.table.is-in [data-rowidx="2"] .cell { transition-delay: 180ms; }
.table.is-in [data-rowidx="3"] .cell { transition-delay: 280ms; }
.table.is-in [data-rowidx="4"] .cell { transition-delay: 380ms; }
.table.is-in [data-rowidx="5"] .cell { transition-delay: 480ms; }
.table.is-in [data-rowidx="6"] .cell { transition-delay: 580ms; }
.table.is-in [data-rowidx="7"] .cell { transition-delay: 680ms; }

@media (prefers-reduced-motion: reduce) {
  .cell { opacity: 1; transform: none; transition: none; }
}

/* head row */
.row-head .cell {
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
  font: 500 11px/1.4 var(--font-mono);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  border-bottom: 1px solid var(--border-strong);
  background: color-mix(in srgb, #ffffff 2%, transparent);
}
.col-tag { color: var(--accent-primary); margin-right: 6px; }
.col-tag.never-tag { color: var(--text-tertiary); }
.col-tag.share-tag { color: var(--accent-primary); }

/* SOURCE column */
.c-src {
  flex-direction: column;
  gap: 4px;
  align-items: flex-start;
  color: var(--text-primary);
}
.src-name { font: 500 16px/1.3 var(--font-body); color: var(--text-primary); }
.src-ex { font-size: 11px; color: var(--text-quaternary); letter-spacing: 0.02em; }

/* READ */
.c-read { color: var(--text-primary); }
.c-read .check {
  color: var(--accent-primary);
  font-weight: 700;
  flex-shrink: 0;
  text-shadow: 0 0 8px color-mix(in srgb, var(--accent-primary) 50%, transparent);
}

/* NEVER */
.c-never { color: var(--text-tertiary); }
.c-never .ex {
  color: var(--text-quaternary);
  font-family: var(--font-mono);
  flex-shrink: 0;
  width: 12px;
  text-align: center;
}
.c-never .strike {
  /* strikethrough removed — text-tertiary color + × icon already convey negation */
}

/* CONTROL */
.c-share { color: var(--text-secondary); }
.c-share .dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--accent-primary);
  box-shadow: 0 0 8px color-mix(in srgb, var(--accent-primary) 60%, transparent);
  flex-shrink: 0;
  position: relative;
  top: 5px;
}

/* hover row highlight */
.row:not(.row-head):not(.row-foot):hover .cell {
  background: color-mix(in srgb, var(--accent-primary) 4%, transparent);
}

/* foot row spans the rest */
.row-foot .cell { border-bottom: none; }
.row-foot .src-name { color: var(--text-secondary); font-style: italic; }
.row-foot .cell-merge {
  grid-column: 2 / -1;
  color: var(--text-tertiary);
  font-style: italic;
  font-size: 14px;
}

/* ─────────── COMMITMENTS — 4-card row below table ─────────── */
.commitments {
  margin-top: var(--space-4xl);
}
.commitments-label {
  font: 500 11px/1.4 var(--font-mono);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin: 0 0 var(--space-lg);
}
.commit-grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: var(--space-lg);
}
.commit {
  position: relative;
  padding: var(--space-lg);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  background: color-mix(in srgb, #ffffff 2%, transparent);
  opacity: 0;
  transform: perspective(1100px) rotateX(-22deg) translateY(40px) scale(0.92);
  transform-origin: 50% 100%;
  transition:
    opacity 560ms var(--ease-standard),
    transform 560ms cubic-bezier(.18, .89, .32, 1.18),
    border-color 220ms var(--ease-standard);
}
.commitments.is-in .commit { opacity: 1; transform: perspective(1100px) rotateX(0) translateY(0) scale(1); }
.commitments.is-in .commit:nth-child(1) { transition-delay: 0ms; }
.commitments.is-in .commit:nth-child(2) { transition-delay: 130ms; }
.commitments.is-in .commit:nth-child(3) { transition-delay: 260ms; }
.commitments.is-in .commit:nth-child(4) { transition-delay: 390ms; }
.commit:hover {
  border-color: color-mix(in srgb, var(--accent-primary) 35%, transparent);
  transform: translateY(-2px);
}

@media (prefers-reduced-motion: reduce) {
  .commit { opacity: 1; transform: none; transition: none; }
  .commit:hover { transform: none; }
}
.commit-mark {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent-primary);
  box-shadow: 0 0 10px color-mix(in srgb, var(--accent-primary) 60%, transparent);
  margin-bottom: var(--space-md);
}
.commitments.is-in .commit-mark { animation: dotPulseOnce 900ms ease-out 1 both; }
.commitments.is-in .commit:nth-child(1) .commit-mark { animation-delay: 320ms; }
.commitments.is-in .commit:nth-child(2) .commit-mark { animation-delay: 450ms; }
.commitments.is-in .commit:nth-child(3) .commit-mark { animation-delay: 580ms; }
.commitments.is-in .commit:nth-child(4) .commit-mark { animation-delay: 710ms; }
@keyframes dotPulseOnce {
  0%   { transform: scale(1);   box-shadow: 0 0 10px color-mix(in srgb, var(--accent-primary) 60%, transparent); }
  35%  { transform: scale(1.7); box-shadow: 0 0 24px color-mix(in srgb, var(--accent-primary) 90%, transparent); }
  100% { transform: scale(1);   box-shadow: 0 0 10px color-mix(in srgb, var(--accent-primary) 60%, transparent); }
}
@media (prefers-reduced-motion: reduce) {
  .commitments.is-in .commit-mark { animation: none; }
}
.commit-title {
  font: 500 16px/1.35 var(--font-body);
  color: var(--text-primary);
  margin: 0 0 var(--space-sm);
  letter-spacing: -0.005em;
}
.commit-title em {
  font-style: normal;
  color: var(--accent-primary);
}
.commit-desc {
  font: 400 13px/1.55 var(--font-body);
  color: var(--text-secondary);
  margin: 0;
}

@media (max-width: 1100px) {
  .commit-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 600px) {
  .commit-grid { grid-template-columns: 1fr; }
}

/* mobile: each source becomes a stacked card */
@media (max-width: 900px) {
  .table {
    display: flex;
    flex-direction: column;
    border-top: none;
    border-bottom: none;
    gap: var(--space-md);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    gap: var(--space-sm);
  }
  .row-head { display: none; }
  .row-foot .cell-merge { grid-column: 1; }
  .cell {
    padding: 6px 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--border-subtle) 80%, transparent);
  }
  .row > .cell:last-child { border-bottom: none; }
  .c-read::before  { content: 'READS · ';  color: var(--accent-primary); font: 500 10px/1 var(--font-mono); letter-spacing: 0.1em; margin-right: 6px; }
  .c-never::before { content: 'NEVER · ';  color: var(--text-tertiary);  font: 500 10px/1 var(--font-mono); letter-spacing: 0.1em; margin-right: 6px; }
  .c-share::before { content: 'YOU · ';    color: var(--accent-primary); font: 500 10px/1 var(--font-mono); letter-spacing: 0.1em; margin-right: 6px; }
}
</style>

<script>
const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
const targets = document.querySelectorAll<HTMLElement>('.rdr .table, .rdr .commitments');

if (reduceMotion) {
  targets.forEach(t => t.classList.add('is-in'));
} else {
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) e.target.classList.add('is-in');
      else                  e.target.classList.remove('is-in');
    }
  }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
  targets.forEach(t => io.observe(t));
}
</script>
