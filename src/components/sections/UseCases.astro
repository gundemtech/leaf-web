---
import LeafCard from '../LeafCard.astro';
import LeafEyebrow from '../LeafEyebrow.astro';
const cases = [
  { title: 'Async handoff between teammates', q: 'Where did Anton stop on the auth refactor?', a: 'Leaf shows last commit, last Slack decision, open PR.' },
  { title: 'Prod-bug archaeology', q: 'When did we last touch this file? Who? Why?', a: 'Leaf maps commits ↔ Linear issues ↔ Slack threads.' },
  { title: 'Decision archaeology', q: 'Why did we pick GRDB over CoreData?', a: 'Leaf surfaces the Slack thread + PR description.' },
  { title: 'AI coaching with real context', q: 'Suggest a sprint plan based on my actual work.', a: 'Claude Code reads your week + team velocity.' },
];
---
<section id="use-cases" class="use-cases">
  <div class="wrap">
    <LeafEyebrow number="04" label="IN PRACTICE" />
    <h2 class="t-display">What Leaf actually solves.</h2>

    <ul class="list">
      {cases.map(c => (
        <li>
          <LeafCard variant="raised" padding="generous">
            <h3 class="t-title-md">{c.title}</h3>
            <p class="q t-body-lg mono">"{c.q}"</p>
            <p class="a t-body"><span class="arrow">→</span> {c.a}</p>
          </LeafCard>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
.use-cases { padding: var(--space-5xl) 0; }
.use-cases h2 { margin: var(--space-md) 0 var(--space-3xl); }
.list { display: flex; flex-direction: column; gap: var(--space-md); }
.list h3 { margin-bottom: var(--space-sm); }
.q { color: var(--text-primary); margin-bottom: var(--space-sm); font-style: italic; }
.a { color: var(--text-secondary); }
.arrow { color: var(--accent-primary); }
</style>
