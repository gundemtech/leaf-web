---
interface Props {
  number?: string; // "01"
  label: string; // "ON YOUR MAC"
}
const { number, label } = Astro.props;
---
<div class="eyebrow t-label">
  <span class="leading" aria-hidden="true"></span>
  {number && <span class="num mono">№{number}</span>}
  {number && <span class="dot">·</span>}
  <span class="text">{label}</span>
</div>

<style>
.eyebrow { display: inline-flex; align-items: center; gap: var(--space-sm); color: var(--accent-primary); }
.leading {
  width: 24px; height: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--accent-primary) 100%);
}
.num { font-family: var(--font-mono); color: var(--accent-emphasis); }
.dot { color: var(--text-quaternary); }
.text { color: var(--accent-primary); }
</style>
