---
import AuthLayout from '../layouts/AuthLayout.astro';
import LeafLogo from '../components/LeafLogo.astro';
import LeafButton from '../components/LeafButton.astro';
import LeafCard from '../components/LeafCard.astro';
import LeafBadge from '../components/LeafBadge.astro';
import { vLatest } from '../lib/version';

// Stable "always latest" permalink — the served redirect points at the newest DMG.
const DMG_URL = 'https://updates.gundem.tech/Leaf.dmg';
// Build-time fallback version label (enriched at runtime by the live fetch below).
---
<AuthLayout title="Dashboard: Leaf" description="Your Leaf account.">
  <div class="dash-wrap">
    <header class="dash-head">
      <a href="/" aria-label="Leaf home"><LeafLogo size={28} withWordmark /></a>
      <div class="head-right">
        <span class="t-body-sm muted">Signed in as <span class="email-echo mono" data-user-email>-</span></span>
        <LeafButton variant="ghost" size="sm" id="signout-btn">Sign out</LeafButton>
      </div>
    </header>

    <main class="dash-grid">
      <LeafCard variant="raised" padding="generous" class="card-section">
        <h2 class="t-title-md">Account</h2>
        <dl class="kv">
          <dt>Name</dt>           <dd data-field="name">-</dd>
          <dt>Email</dt>          <dd class="mono" data-field="email">-</dd>
          <dt>Provider</dt>       <dd data-field="provider">-</dd>
          <dt>Member since</dt>   <dd data-field="memberSince">-</dd>
          <dt>Plan</dt>           <dd><LeafBadge variant="accent">Solo</LeafBadge></dd>
        </dl>
      </LeafCard>

      <LeafCard variant="raised" padding="generous" class="card-section">
        <h2 class="t-title-md">Download</h2>
        <p class="t-body muted">macOS 14+ (Sonoma) · Apple Silicon &amp; Intel · ~24 MB · auto-updates via Sparkle</p>
        <div class="download-row">
          <LeafButton variant="primary" size="lg" href={DMG_URL} download>Download Leaf.dmg →</LeafButton>
          {/* Build-time fallback label — enriched at runtime by the live fetch in dashboard.ts. */}
          <span class="t-body-sm muted">Latest: <span class="mono" data-version-label>{vLatest}</span></span>
        </div>

        {/* Live version detail, populated client-side from updates.gundem.tech/releases.json.
            Hidden until the fetch succeeds; the static label above is the no-JS fallback. */}
        <div class="version-live" data-version-live hidden>
          <a class="version-dmg mono t-body-sm" data-version-dmg href={DMG_URL} download>
            Download <span data-version-dmg-name>this version</span> →
          </a>
          <details class="version-history">
            <summary class="t-body-sm" data-version-history-summary>Version history</summary>
            <ol class="version-history-list" data-version-history-list></ol>
          </details>
        </div>

        <details class="checksum">
          <summary class="t-body-sm">Checksums &amp; signatures</summary>
          <div class="checksum-body">
            <p class="mono">SHA-256: <span class="dim">(verify against <a href="https://updates.gundem.tech/Leaf.dmg.sha256" target="_blank" rel="noopener">updates.gundem.tech/Leaf.dmg.sha256</a>)</span></p>
            <p class="mono">EdDSA sig: <span class="dim">(verified by Sparkle on install)</span></p>
            <p class="t-body-sm muted">Notarized by Apple · Developer ID signed.</p>
          </div>
        </details>
      </LeafCard>

      <LeafCard variant="raised" padding="generous" class="card-section danger-card">
        <h2 class="t-title-md">Danger zone</h2>
        <p id="delete-confirm-help" class="t-body muted">
          Delete your account, including all team memberships, share lists, and
          identity keys held on the relay. <strong>Your local Mac data is not affected.</strong>
          Wipe that from the macOS app's Settings → Danger zone.
        </p>
        <label class="delete-confirm-label t-body-sm muted" for="delete-confirm-input">
          Type <strong>DELETE</strong> to confirm:
        </label>
        <input
          type="text"
          id="delete-confirm-input"
          class="delete-confirm-input mono"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          aria-describedby="delete-confirm-help"
          placeholder="DELETE"
        />
        <LeafButton variant="destructive" size="md" id="delete-btn" disabled>Delete account →</LeafButton>
      </LeafCard>
    </main>
  </div>
</AuthLayout>

<style>
.dash-wrap {
  width: 100%;
  max-width: 760px;
  padding: var(--space-3xl) var(--space-xl);
  align-self: flex-start;
  margin-top: 5vh;
}
.dash-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3xl);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--border-subtle);
}
.head-right { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
.muted { color: var(--text-secondary); }
.dim { color: var(--text-tertiary); }

.dash-grid { display: flex; flex-direction: column; gap: var(--space-lg); }
.card-section h2 { margin-bottom: var(--space-md); }

.kv {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: var(--space-sm) var(--space-lg);
  font-size: 14px;
}
.kv dt { color: var(--text-tertiary); }
.kv dd { color: var(--text-primary); margin: 0; }

.download-row { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; margin-top: var(--space-md); }
.checksum { margin-top: var(--space-md); }
.checksum summary { color: var(--accent-primary); cursor: pointer; font-size: 13px; }
.checksum-body { padding-top: var(--space-sm); display: flex; flex-direction: column; gap: var(--space-xs); }
.checksum-body .mono { font-size: 12px; color: var(--text-secondary); }

.danger-card { border-color: color-mix(in srgb, var(--status-danger) 30%, var(--border-subtle)); }
.danger-card h2 { color: var(--status-danger); }
.danger-card .muted { margin-bottom: var(--space-md); }
.delete-confirm-label { display: block; margin-bottom: var(--space-xs); }
.delete-confirm-input {
  display: block;
  width: 100%;
  max-width: 220px;
  margin-bottom: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  background: transparent;
  color: var(--text-primary);
  font-size: 14px;
}
.delete-confirm-input:focus-visible {
  outline: 2px solid var(--status-danger);
  outline-offset: 1px;
}

.email-echo { color: var(--text-primary); font-size: 12px; }

/* Live version detail (populated client-side) */
.version-live { margin-top: var(--space-md); display: flex; flex-direction: column; gap: var(--space-sm); }
.version-dmg { color: var(--accent-primary); text-decoration: none; }
.version-dmg:hover { text-decoration: underline; }
.version-history summary { color: var(--accent-primary); cursor: pointer; font-size: 13px; }
.version-history-list {
  list-style: none;
  margin: var(--space-sm) 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}
.version-history-item { padding-top: var(--space-sm); border-top: 1px solid var(--border-subtle); }
.version-history-item:first-child { border-top: none; padding-top: 0; }
.version-history-head { display: flex; align-items: baseline; gap: var(--space-sm); flex-wrap: wrap; }
.version-history-head .ver { color: var(--text-primary); font-size: 13px; }
.version-history-head .date { color: var(--text-tertiary); font-size: 12px; }
.version-history-head .yanked { color: var(--status-danger); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; }
.version-history-notes { margin: var(--space-xs) 0 0; padding-left: var(--space-lg); display: flex; flex-direction: column; gap: 2px; }
.version-history-notes li { color: var(--text-secondary); font-size: 12px; line-height: 1.45; list-style: disc; }
.version-history-notes li .kind { color: var(--text-tertiary); }
</style>

<script>
  import '../scripts/dashboard';
  import '../scripts/dashboard-versions';
</script>
