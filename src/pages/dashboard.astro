---
import AuthLayout from '../layouts/AuthLayout.astro';
import LeafLogo from '../components/LeafLogo.astro';
import LeafButton from '../components/LeafButton.astro';
import LeafCard from '../components/LeafCard.astro';
import LeafBadge from '../components/LeafBadge.astro';
import LeafThemeToggle from '../components/LeafThemeToggle.astro';
import { LEAF_VERSION, LEAF_VERSION_TAG, LEAF_DMG_URL, LEAF_DMG_SHA256_URL } from '../lib/version';

const DMG_URL = LEAF_DMG_URL;
---
<AuthLayout title="Dashboard: Leaf" description="Your Leaf account.">
  <div class="dash-wrap">
    <header class="dash-head">
      <a href="/" aria-label="Leaf home"><LeafLogo size={28} withWordmark /></a>
      <div class="head-right">
        <span class="t-body-sm muted">Signed in as <span class="email-echo mono" data-user-email>-</span></span>
        <LeafThemeToggle />
        <LeafButton variant="ghost" size="sm" id="signout-btn">Sign out</LeafButton>
      </div>
    </header>

    <main class="dash-grid">
      <LeafCard variant="raised" padding="generous" class="card-section">
        <h2 class="t-title-md">Account</h2>
        <dl class="kv">
          <dt>Name</dt>           <dd data-field="name">-</dd>
          <dt>Email</dt>          <dd class="mono" data-field="email">-</dd>
          <dt>Provider</dt>       <dd data-field="provider">-</dd>
          <dt>Member since</dt>   <dd data-field="memberSince">-</dd>
          <dt>Device</dt>         <dd data-field="device">-</dd>
          <dt>Plan</dt>           <dd><LeafBadge variant="accent">Solo</LeafBadge></dd>
        </dl>

        <div class="set-password" data-set-password hidden>
          <div class="set-password-head">
            <p class="t-body-sm muted">Want to sign in with email + password too? Set a password for your account.</p>
            <LeafButton variant="secondary" size="sm" id="set-password-toggle">Set a password</LeafButton>
          </div>

          <form class="set-password-form" data-set-password-form hidden novalidate>
            <label class="sp-field">
              <span class="sp-label t-body-sm">New password</span>
              <input type="password" name="password" autocomplete="new-password" data-sp-password />
            </label>

            <ul class="password-requirements" data-sp-requirements aria-live="polite">
              <li class="requirement" data-rule="length"><span class="req-icon" aria-hidden="true"></span>At least 8 characters</li>
              <li class="requirement" data-rule="upper"><span class="req-icon" aria-hidden="true"></span>An uppercase letter</li>
              <li class="requirement" data-rule="lower"><span class="req-icon" aria-hidden="true"></span>A lowercase letter</li>
              <li class="requirement" data-rule="number"><span class="req-icon" aria-hidden="true"></span>A number</li>
              <li class="requirement" data-rule="symbol"><span class="req-icon" aria-hidden="true"></span>A symbol</li>
            </ul>

            <label class="sp-field">
              <span class="sp-label t-body-sm">Confirm password</span>
              <input type="password" name="confirm" autocomplete="new-password" data-sp-confirm />
            </label>

            <div class="sp-actions">
              <LeafButton type="submit" variant="primary" size="sm">Save password</LeafButton>
            </div>

            <p class="sp-error" data-sp-error role="alert" hidden></p>
            <p class="sp-success" data-sp-success role="status" hidden></p>
          </form>
        </div>
      </LeafCard>

      <LeafCard variant="raised" padding="generous" class="card-section">
        <h2 class="t-title-md">Download</h2>
        <p class="t-body muted">macOS 14+ (Sonoma) · Apple Silicon &amp; Intel · ~24 MB · auto-updates via Sparkle</p>
        <div class="download-row">
          <LeafButton variant="primary" size="lg" href={DMG_URL} download>Download Leaf.dmg →</LeafButton>
          <span class="t-body-sm muted">Latest: <span class="mono">{LEAF_VERSION_TAG}</span></span>
        </div>
        <details class="checksum">
          <summary class="t-body-sm">Checksums &amp; signatures</summary>
          <div class="checksum-body">
            <p class="mono">SHA-256: <a class="dim" href={LEAF_DMG_SHA256_URL}>Leaf-{LEAF_VERSION}.dmg.sha256</a></p>
            <p class="mono">EdDSA sig: <span class="dim">(verified by Sparkle on install)</span></p>
            <p class="t-body-sm muted">Notarized by Apple · Developer ID signed.</p>
          </div>
        </details>
      </LeafCard>

      <LeafCard variant="raised" padding="generous" class="card-section danger-card">
        <h2 class="t-title-md">Danger zone</h2>
        <p class="t-body muted">
          Delete your account, including all team memberships, share lists, and
          identity keys held on the relay. <strong>Your local Mac data is not affected.</strong>
          Wipe that from the macOS app's Settings → Danger zone.
        </p>
        <LeafButton variant="destructive" size="md" id="delete-btn">Delete account →</LeafButton>
      </LeafCard>
    </main>
  </div>

  <!-- Delete-account confirmation modal (hidden by default; wired in dashboard.ts) -->
  <div class="modal-overlay" data-delete-modal role="presentation" hidden>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title" data-delete-dialog>
      <h2 class="t-title-md" id="delete-modal-title">Delete account?</h2>
      <p class="t-body modal-text">
        This removes team memberships and identity keys held on the relay.
        Your local Mac data is not touched — wipe that from the macOS app's
        Settings → Danger zone.
      </p>
      <p class="modal-error" data-delete-error role="alert" hidden></p>
      <div class="modal-actions">
        <LeafButton variant="secondary" size="md" id="delete-cancel-btn">Cancel</LeafButton>
        <LeafButton variant="destructive" size="md" id="delete-confirm-btn">Delete account</LeafButton>
      </div>
    </div>
  </div>
</AuthLayout>

<style>
.dash-wrap {
  width: 100%;
  max-width: 760px;
  padding: var(--space-3xl) var(--space-xl);
  align-self: flex-start;
  margin-top: 5vh;
}
.dash-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3xl);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--border-subtle);
}
.head-right { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
.muted { color: var(--text-secondary); }
.dim { color: var(--text-tertiary); }

.dash-grid { display: flex; flex-direction: column; gap: var(--space-lg); }
.card-section h2 { margin-bottom: var(--space-md); }

.kv {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: var(--space-sm) var(--space-lg);
  font-size: 14px;
}
.kv dt { color: var(--text-tertiary); }
.kv dd { color: var(--text-primary); margin: 0; }

.download-row { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; margin-top: var(--space-md); }
.checksum { margin-top: var(--space-md); }
.checksum summary { color: var(--accent-primary); cursor: pointer; font-size: 13px; }
.checksum-body { padding-top: var(--space-sm); display: flex; flex-direction: column; gap: var(--space-xs); }
.checksum-body .mono { font-size: 12px; color: var(--text-secondary); }

.danger-card { border-color: color-mix(in srgb, var(--status-danger) 30%, var(--border-subtle)); }
.danger-card h2 { color: var(--status-danger); }
.danger-card .muted { margin-bottom: var(--space-md); }

.email-echo { color: var(--text-primary); font-size: 12px; }

/* Set-password control (OAuth users only) */
.set-password {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--border-subtle);
}
.set-password-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  flex-wrap: wrap;
}
.set-password-head .muted { margin: 0; flex: 1; min-width: 200px; }

.set-password-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--surface-canvas);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
}
/* The `hidden` attribute must win over the flex display above (UA [hidden] has
   too-low specificity), so the form stays collapsed until "Set a password". */
.set-password[hidden], .set-password-form[hidden] { display: none; }
.sp-field { display: flex; flex-direction: column; gap: var(--space-xs); }
.sp-label { color: var(--text-secondary); font-weight: 500; }
.sp-field input {
  height: 36px;
  padding: 0 var(--space-md);
  background: var(--surface-raised);
  color: var(--text-primary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  font: 400 15px/1 var(--font-body);
  transition: border-color var(--dur-snap) var(--ease-standard);
}
.sp-field input:hover { border-color: var(--border-strong); }
.sp-field input:focus-visible { outline: none; border-color: var(--border-focus); }

.set-password-form .password-requirements {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xs) var(--space-md);
}
.set-password-form .requirement {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  color: var(--text-tertiary);
  font-size: 12px;
  line-height: 1.4;
  transition: color var(--dur-snap) var(--ease-standard);
}
.set-password-form .req-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  flex: none;
}
.set-password-form .req-icon::before { content: '✗'; font-size: 11px; line-height: 1; }
.set-password-form .requirement.met { color: var(--status-success); }
.set-password-form .requirement.met .req-icon::before { content: '✓'; }

.sp-actions { display: flex; }
.sp-error { color: var(--status-danger); font-size: 13px; margin: 0; }
.sp-success { color: var(--status-success); font-size: 13px; margin: 0; }

/* Reveal animation: when the form un-hides (hidden attr removed), it's flex
   again — animate it in (fade + slide-down). */
.set-password-form:not([hidden]) {
  animation: sp-form-in var(--dur-short) var(--ease-standard) both;
}
@keyframes sp-form-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Set-password success/error: subtle fade-in when they appear. */
.sp-error:not([hidden]),
.sp-success:not([hidden]) {
  animation: sp-msg-in var(--dur-short) var(--ease-standard) both;
}
@keyframes sp-msg-in {
  from { opacity: 0; transform: translateY(-3px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Delete-account modal ─── */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  background: color-mix(in srgb, var(--surface-canvas) 70%, transparent);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  animation: modal-overlay-in var(--dur-short) var(--ease-standard) both;
}
/* [hidden] must win over the flex display above. */
.modal-overlay[hidden] { display: none; }
.modal-overlay.is-closing { animation: modal-overlay-out var(--dur-short) var(--ease-standard) both; }

.modal-dialog {
  width: 100%;
  max-width: 420px;
  padding: var(--space-xl);
  background: var(--surface-raised);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--elev-modal);
  animation: modal-dialog-in 180ms var(--ease-emphasized) both;
}
.modal-overlay.is-closing .modal-dialog { animation: modal-dialog-out 180ms var(--ease-standard) both; }
.modal-dialog h2 { margin: 0 0 var(--space-sm); color: var(--status-danger); }
.modal-dialog .modal-text { color: var(--text-secondary); margin: 0 0 var(--space-lg); }
.modal-error { color: var(--status-danger); font-size: 13px; margin: 0 0 var(--space-md); }
.modal-error:not([hidden]) { animation: sp-msg-in var(--dur-short) var(--ease-standard) both; }
.modal-actions { display: flex; justify-content: flex-end; gap: var(--space-sm); }

@keyframes modal-overlay-in { from { opacity: 0; } to { opacity: 1; } }
@keyframes modal-overlay-out { from { opacity: 1; } to { opacity: 0; } }
@keyframes modal-dialog-in {
  from { opacity: 0; transform: translateY(8px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes modal-dialog-out {
  from { opacity: 1; transform: translateY(0) scale(1); }
  to   { opacity: 0; transform: translateY(8px) scale(0.97); }
}

@media (prefers-reduced-motion: reduce) {
  .set-password-form:not([hidden]),
  .sp-error:not([hidden]),
  .sp-success:not([hidden]),
  .modal-overlay,
  .modal-overlay.is-closing,
  .modal-dialog,
  .modal-overlay.is-closing .modal-dialog,
  .modal-error:not([hidden]) {
    animation: none;
  }
}
</style>

<script>
  import '../scripts/dashboard';
</script>

<script>
// Inline fallback handler (runs before module bundle resolves).
// Real auth-gate + Supabase flow lives in src/scripts/dashboard.ts.
// Delete is handled entirely by the module (custom in-page modal) — no inline
// fallback, so no native confirm()/alert() can fire before the bundle loads.
const signoutBtn = document.getElementById('signout-btn') as HTMLButtonElement | null;

signoutBtn?.addEventListener('click', async () => {
  const sb = (window as any).supabase;
  if (!sb) { window.location.href = '/signup'; return; }
  await sb.auth.signOut();
  window.location.href = '/';
});
</script>
