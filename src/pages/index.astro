---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafNav from '../components/LeafNav.astro';
import LeafFooter from '../components/LeafFooter.astro';
import HeroLanding from '../components/sections/HeroLanding.astro';
import LayerACapture from '../components/sections/LayerACapture.astro';
import LayerBIntegrations from '../components/sections/LayerBIntegrations.astro';
import ThreeSurfaces from '../components/sections/ThreeSurfaces.astro';
import UseCases from '../components/sections/UseCases.astro';
import PrivacyTeaser from '../components/sections/PrivacyTeaser.astro';
import PricingTeaser from '../components/sections/PricingTeaser.astro';
import FAQ from '../components/sections/FAQ.astro';
import WaitlistCTA from '../components/sections/WaitlistCTA.astro';
---
<BaseLayout
  title="Leaf — Memory for AI dev teams"
  description="Your team's working memory, captured automatically across your tools. Queryable from Claude Code, Cursor, and Slack. Private by architecture — managers can't peek without your consent."
>
  <LeafNav slot="nav" />
  <HeroLanding />
  <LayerACapture />
  <LayerBIntegrations />
  <ThreeSurfaces />
  <UseCases />
  <PrivacyTeaser />
  <PricingTeaser />
  <FAQ />
  <WaitlistCTA />
  <LeafFooter slot="footer" />
</BaseLayout>
