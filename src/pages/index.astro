---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafNav from '../components/LeafNav.astro';
import LeafFooter from '../components/LeafFooter.astro';
import HeroLanding from '../components/sections/HeroLanding.astro';
import Problem from '../components/sections/Problem.astro';
import UseCases from '../components/sections/UseCases.astro';
import ReadDontRead from '../components/sections/ReadDontRead.astro';
import WaitlistCTA from '../components/sections/WaitlistCTA.astro';
---
<BaseLayout
  title="Leaf: the shared brain for engineering orgs"
  description="The layer that remembers what your team actually did. Captured automatically from the tools you already use, surfaced back on each person's terms. No standups, no manager dashboards, no screen recording."
>
  <LeafNav slot="nav" />
  <HeroLanding />
  <Problem />
  <UseCases />
  <ReadDontRead />
  <WaitlistCTA />
  <LeafFooter slot="footer" />
</BaseLayout>
